---
import T from "../components/T";
import "../styles/global.css";

interface BaseLayoutProps {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Gastón Gómez – Front-End Developer",
  description = "Portfolio of Gastón Gómez, Front-End Developer specialized in Angular, React, Ionic and TypeScript.",
  image = "/avatar.jpg",
} = Astro.props as BaseLayoutProps;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Gastón Gómez",
      "jobTitle": "Front-End Developer",
      "url": Astro.url.origin,
      "sameAs": [
        "https://www.linkedin.com/in/gassssty/",
        "https://github.com/gasssston",
        "https://x.com/gassssty_"
      ]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,400&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>
    <!-- Loader -->
    <div
      id="loader"
      class="fixed inset-0 flex flex-col items-center justify-center gap-4"
      style="background: var(--loader-bg); z-index: 9999; transition: opacity 0.5s ease;"
    >
      <div
        style="
          width: 40px;
          height: 40px;
          border: 2px solid var(--border-strong);
          border-top-color: var(--accent);
          border-radius: 50%;
          animation: spin 0.75s linear infinite;
        "
      ></div>
      <span
        class="text-sm font-medium"
        style="color: var(--text-muted); letter-spacing: 0.08em; text-transform: uppercase; font-family: 'DM Sans', sans-serif;"
      >
        <T client:load k="loader.text" />
      </span>
    </div>

    <script>
      window.addEventListener("load", () => {
        document.documentElement.classList.add("dark");
        const loader = document.getElementById("loader");
        if (!loader) return;
        setTimeout(() => {
          loader.style.opacity = "0";
          setTimeout(() => { loader.style.display = "none"; }, 600);
        }, 900);
      });

      import { initI18n, changeLang } from "../i18n/i18n.js";

      initI18n().then((i18n) => {
        window.setLang = changeLang;
        document.documentElement.lang = i18n.language;
        i18n.on("languageChanged", (lng) => {
          document.documentElement.lang = lng;
        });
      });
    </script>

    <!-- Background decoration -->
    <div class="page-decor">
      <div class="dot-grid"></div>
      <div class="orb orb-1"></div>
      <div class="orb orb-2"></div>
      <div class="orb orb-3"></div>
    </div>

    <slot />

    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js" onload="AOS.init({ duration: 700, once: true, offset: 60 })"></script>
  </body>
</html>

<style>
  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>
