---
import T from "../components/T";
import "../styles/global.css";

interface BaseLayoutProps {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Gastón Gómez – Front-End Developer",
  description = "Portfolio profesional de Gastón Gómez, desarrollador Front-End especializado en Angular, React, Ionic y TypeScript.",
  image = "/avatar.jpg",
} = Astro.props as BaseLayoutProps;
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Gastón Gómez",
      "jobTitle": "Front-End Developer",
      "url": Astro.url.origin,
      "sameAs": [
        "https://www.linkedin.com/in/gassssty/",
        "https://github.com/gasssston",
        "https://x.com/gassssty_"
      ]
    })} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body class="font-inter">
    <div
      id="loader"
      class="fixed inset-0 flex items-center justify-center"
      style="
    background: var(--loader-bg);
    z-index: 9999;
    transition: opacity 0.4s ease;
  "
    >
      <span
        class="text-4xl font-bold opacity-0 text-center"
        style="
      color: var(--loader-text);
      animation: fadeIn 0.8s ease forwards;
    "
      >
        <T client:load k="loader.text" />
      </span>
    </div>
    <script>
      window.addEventListener("load", () => {
        document.documentElement.classList.add("dark");
        const loader = document.getElementById("loader");
        if (!loader) return;
        setTimeout(() => {
          loader.style.opacity = "0";
          setTimeout(() => {
            loader.style.display = "none";
          }, 600);
        }, 1000);
      });

      import { initI18n, changeLang } from "../i18n/i18n.js";

      initI18n().then((i18n) => {
        window.setLang = changeLang;
        document.documentElement.lang = i18n.language;
        i18n.on("languageChanged", (lng) => {
          document.documentElement.lang = lng;
        });
      });
    </script>
    <div class="page-decor">
      <div class="page-decor-side page-decor-left"></div>
      <div class="page-decor-side page-decor-right"></div>
    </div>
    <slot />

    <script src="https://unpkg.com/aos@2.3.4/dist/aos.js" onload="AOS.init()"
    ></script>
  </body>
</html>
