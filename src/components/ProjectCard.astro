---
interface ProjectCardProps {
  title: string;
  description: string;
  tech: string[];
  link: string;
}

const { title, description, tech, link } = Astro.props as ProjectCardProps;
---

<div
  class="bg-white dark:bg-gray-800 shadow rounded-lg p-6 hover:-translate-y-1 transition"
  data-aos="fade-up"
>
  <h4 class="text-xl font-semibold mb-2">{title}</h4>
  <p class="text-gray-600 dark:text-gray-300 mb-4">{description}</p>

  <div class="flex flex-wrap gap-2 mb-4">
    {
      tech.map((t) => (
        <span class="px-2 py-1 text-xs bg-gray-200 dark:bg-gray-700 rounded">
          {t}
        </span>
      ))
    }
  </div>

  <a
    href={link}
    target="_blank"
    class="text-blue-600 dark:text-blue-400 hover:underline">Ver proyecto</a
  >
</div>
