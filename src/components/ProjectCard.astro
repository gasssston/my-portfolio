---
interface ProjectCardProps {
  title: string;
  description: string;
  tech: string[];
  link: string;
}

const { title, description, tech, link } = Astro.props as ProjectCardProps;
---

<div
  class="shadow-md rounded-lg p-6 hover:-translate-y-1 hover:transition-all duration-200 h-full"
  data-aos="fade-up"
  style="background-color: var(--card-bg); color: var(--card-text);"
>
  <h4 class="text-xl font-semibold mb-2">{title}</h4>

  <p class="mb-4" style="color: var(--card-subtext);">
    {description}
  </p>

  <div class="flex flex-wrap gap-2 mb-4">
    {
      tech.map((t) => (
        <span
          class="px-2 py-1 text-xs rounded"
          style="background-color: var(--card-tag-bg); color: var(--card-text);"
        >
          {t}
        </span>
      ))
    }
  </div>

  <a
    href={link}
    target="_blank"
    class="hover:underline"
    style="color: var(--card-link);"
  >
    Ver proyecto
  </a>
</div>
