---
import type { ProjectCardProps } from "./Projects.astro";
import T from "./T";

const { title, descriptionKey, tech, link } = Astro.props as ProjectCardProps;
---

<article class="project-card">
  <!-- Top accent dot -->
  <div
    class="w-2 h-2 rounded-full mb-5"
    style="background: linear-gradient(135deg, var(--accent), var(--accent2));"
  ></div>

  <h4 class="text-lg font-bold mb-3" style="font-family: 'Syne', sans-serif; color: var(--card-text);">
    {title}
  </h4>

  <p class="text-sm leading-relaxed mb-5 flex-1" style="color: var(--card-subtext);">
    <T client:load k={descriptionKey} />
  </p>

  <div class="flex flex-wrap gap-2 mb-5">
    {tech.map((t) => (
      <span class="tech-tag">{t}</span>
    ))}
  </div>

  <a
    href={link}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-flex items-center gap-1.5 text-sm font-semibold transition-all duration-200"
    style="color: var(--card-link);"
  >
    <T client:load k="project.view" />
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
      <polyline points="15 3 21 3 21 9"/>
      <line x1="10" y1="14" x2="21" y2="3"/>
    </svg>
  </a>
</article>
