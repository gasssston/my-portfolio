---
import ProjectCard from "./ProjectCard.astro";
import T from "./T";

export interface ProjectCardProps {
  title: string;
  descriptionKey: string;
  tech: string[];
  link: string;
}
import { supabase } from "../lib/supabase";

const { data, error } = await supabase.from("projects").select("*");

const projects = data?.map((projectBBDD) => ({
  title: projectBBDD.title,
  descriptionKey: projectBBDD.description_key,
  tech: JSON.parse(projectBBDD.tech),
  link: projectBBDD.link,
}));
---

<section id="projects" class="max-w-5xl mx-auto py-4 sm:py-32 p-4">
  <h3 class="text-3xl font-semibold mb-10 text-center">
    <T client:load k="projects.title" />
  </h3>
  {
    !error ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects?.map((p) => (
          <ProjectCard {...p} />
        ))}
      </div>
    ) : (
      <p class="text-center text-red-500">
        <T client:load k="projects.error" />
      </p>
    )
  }
</section>
