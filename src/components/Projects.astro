---
import ProjectCard from "./ProjectCard.astro";
import T from "./T";

export interface ProjectCardProps {
  title: string;
  descriptionKey: string;
  tech: string[];
  link: string;
}
import { supabase } from "../lib/supabase";

const { data, error } = await supabase.from("projects").select("*");

const projects = data?.map((projectBBDD) => ({
  title: projectBBDD.title,
  descriptionKey: projectBBDD.description_key,
  tech: JSON.parse(projectBBDD.tech),
  link: projectBBDD.link,
})) as ProjectCardProps[];
---

<section id="projects" class="max-w-5xl mx-auto py-24 px-4">
  <div class="text-center mb-14" data-aos="fade-up">
    <div class="section-label justify-center mb-3">Work</div>
    <h2 class="text-4xl font-bold">
      <T client:load k="projects.title" />
    </h2>
  </div>

  {
    !error ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects?.map((p, i) => (
          <div data-aos="fade-up" data-aos-delay={i * 80}>
            <ProjectCard {...p} />
          </div>
        ))}
      </div>
    ) : (
      <p class="text-center" style="color: var(--text-muted);">
        <T client:load k="projects.error" />
      </p>
    )
  }
</section>
