<section class="max-w-5xl mx-auto text-center py-28" data-aos="fade-up">
  <img
    src="avatar.jpg"
    class="w-48 h-48 rounded-md mx-auto mb-6 shadow-lg object-contain"
  />

  <h2 class="text-5xl font-bold mb-4">Hola, soy Gastón 👋</h2>

  <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
    Front-End Developer especializado en Angular, React, Ionic y TypeScript.
    Construyo productos rápidos, accesibles y con enfoque en experiencia de
    usuario.
  </p>

  <div class="mt-10 flex justify-center gap-4">
    <a
      href="#projects"
      class="px-6 py-3 rounded-lg transition"
      style="
      background-color: var(--btn-primary-bg);
      color: var(--btn-primary-text);
    "
      onmouseover="this.style.backgroundColor='var(--btn-primary-bg-hover)'"
      onmouseout="this.style.backgroundColor='var(--btn-primary-bg)'"
    >
      Ver proyectos
    </a>

    <a
      href="#contact"
      class="px-6 py-3 rounded-lg transition border"
      style="
      border-color: var(--btn-secondary-border);
      color: var(--btn-secondary-text);
    "
      onmouseover="this.style.backgroundColor='var(--btn-secondary-bg-hover)'"
      onmouseout="this.style.backgroundColor='transparent'"
    >
      Contactar
    </a>
  </div>
</section>
