---
import About from "./About.astro";
import T from "./T";
---

<section class="max-w-5xl mx-auto text-center py-4 p-4" data-aos="fade-up">
  <About />

  <div class="flex justify-center gap-4">
    <a
      href="#projects"
      class="px-6 py-3 rounded-lg transition"
      style="
      background-color: var(--btn-primary-bg);
      color: var(--btn-primary-text);
    "
      onmouseover="this.style.backgroundColor='var(--btn-primary-bg-hover)'"
      onmouseout="this.style.backgroundColor='var(--btn-primary-bg)'"
    >
      <T client:load k="hero.projects" />
    </a>

    <a
      href="#contact"
      class="px-6 py-3 rounded-lg transition border"
      style="
      border-color: var(--btn-secondary-border);
      color: var(--btn-secondary-text);
    "
      onmouseover="this.style.backgroundColor='var(--btn-secondary-bg-hover)'"
      onmouseout="this.style.backgroundColor='transparent'"
    >
      <T client:load k="hero.contact" />
    </a>
  </div>
</section>
