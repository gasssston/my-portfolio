<section id="contact" class="max-w-3xl mx-auto py-20" data-aos="fade-up">
  <h3 class="text-3xl font-semibold mb-6 text-center">Contacto</h3>

  <form class="grid gap-4 bg-white dark:bg-gray-800 p-8 rounded-lg shadow">
    <input
      type="text"
      placeholder="Tu nombre"
      class="p-3 rounded bg-gray-100 dark:bg-gray-700"
    />
    <input
      type="email"
      placeholder="Tu email"
      class="p-3 rounded bg-gray-100 dark:bg-gray-700"
    />
    <textarea
      placeholder="Mensaje"
      rows="5"
      class="p-3 rounded bg-gray-100 dark:bg-gray-700"></textarea>

    <button
      class="bg-blue-600 text-white py-3 rounded hover:bg-blue-700 transition"
    >
      Enviar mensaje
    </button>
  </form>
</section>
