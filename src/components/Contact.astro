---
import InputT from "./InputT";
import T from "./T";
import TextareaT from "./TextareaT";
---

<section id="contact" class="max-w-3xl mx-auto py-12 p-4" data-aos="fade-up">
  <h3 class="text-3xl font-semibold mb-6 text-center">
    <T client:load k="contact.title" />
  </h3>

  <form
    class="grid gap-4 p-8 rounded-lg shadow-md"
    style="background-color: var(--form-bg); color: var(--form-text);"
    action="https://formspree.io/f/mlganegn"
    method="POST"
  >
    <div class="grid gap-1">
      <label for="contact-name" class="text-sm font-medium opacity-70">
        <T client:load k="contact.name" />
      </label>
      <InputT
        id="contact-name"
        client:load
        name="name"
        k="contact.name"
        style={{
          padding: "0.75rem",
          borderRadius: "0.375rem",
          backgroundColor: "var(--form-field-bg)",
          color: "var(--form-field-text)",
          border: "1px solid var(--form-field-border)",
        }}
      />
    </div>

    <div class="grid gap-1">
      <label for="contact-email" class="text-sm font-medium opacity-70">
        <T client:load k="contact.email" />
      </label>
      <InputT
        id="contact-email"
        client:load
        type="email"
        name="email"
        k="contact.email"
        style={{
          padding: "0.75rem",
          borderRadius: "0.375rem",
          backgroundColor: "var(--form-field-bg)",
          color: "var(--form-field-text)",
          border: "1px solid var(--form-field-border)",
        }}
      />
    </div>

    <div class="grid gap-1">
      <label for="contact-message" class="text-sm font-medium opacity-70">
        <T client:load k="contact.message" />
      </label>
      <TextareaT
        id="contact-message"
        client:load
        as="textarea"
        name="message"
        k="contact.message"
        style={{
          padding: "0.75rem",
          borderRadius: "0.375rem",
          backgroundColor: "var(--form-field-bg)",
          color: "var(--form-field-text)",
          border: "1px solid var(--form-field-border)",
        }}
      />
    </div>

    <button
      type="submit"
      class="py-3 rounded transition cursor-pointer"
      style="
        background-color: var(--form-btn-bg);
        color: var(--form-btn-text);
      "
      onmouseover="this.style.backgroundColor='var(--form-btn-bg-hover)'"
      onmouseout="this.style.backgroundColor='var(--form-btn-bg)'"
    >
      <T client:load k="contact.send" />
    </button>
  </form>
</section>
