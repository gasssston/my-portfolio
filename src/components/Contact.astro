---
import T from "./T";
---

<section id="contact" class="max-w-3xl mx-auto py-20" data-aos="fade-up">
  <h3 class="text-3xl font-semibold mb-6 text-center">
    <T client:load k="contact.title" />
  </h3>

  <form
    class="grid gap-4 p-8 rounded-lg shadow-md"
    style="background-color: var(--form-bg); color: var(--form-text);"
    action="https://formspree.io/f/mlganegn"
    method="POST"
  >
    <input
      type="text"
      placeholder="Tu nombre"
      class="p-3 rounded"
      name="name"
      style="
        background-color: var(--form-field-bg);
        color: var(--form-field-text);
        border: 1px solid var(--form-field-border);
      "
    />

    <input
      type="email"
      placeholder="Tu email"
      class="p-3 rounded"
      name="email"
      style="
        background-color: var(--form-field-bg);
        color: var(--form-field-text);
        border: 1px solid var(--form-field-border);
      "
    />

    <textarea
      placeholder="Mensaje"
      rows="5"
      class="p-3 rounded"
      name="message"
      style="
        background-color: var(--form-field-bg);
        color: var(--form-field-text);
        border: 1px solid var(--form-field-border);
      "
    ></textarea>

    <button
      type="submit"
      class="py-3 rounded transition"
      style="
        background-color: var(--form-btn-bg);
        color: var(--form-btn-text);
      "
      onmouseover="this.style.backgroundColor='var(--form-btn-bg-hover)'"
      onmouseout="this.style.backgroundColor='var(--form-btn-bg)'"
    >
      Enviar mensaje
    </button>
  </form>
</section>
